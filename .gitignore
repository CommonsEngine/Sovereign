# Dependencies
node_modules/

# Build output
dist/
.next/
.turbo/

# Generated plugin route segments are composed under each shell route group
# (e.g. runtime/app/(platform)/(plugins)/) — symlinks in dev, copies in prod.
# A .gitignore inside each group ignores its composed contents. Source of truth
# is always plugins/[id]/app/.

# Database files (SQLite) — data/ dirs are created next to each app's cwd
# (root, runtime/, apps/auth/), so match at any depth.
**/data/*.db
**/data/*.db-journal
**/data/*.db-wal
**/data/*.db-shm

# User-uploaded avatars (Account plugin, ACC-03) — runtime data, never committed.
**/data/avatars/

# Externally-installed plugins (cloned by scripts/install-plugins.ts) are not
# committed here — they live in their own repositories. Ignore every plugin
# directory except the platform plugins that ship in this monorepo.
/plugins/*/
!/plugins/account/
!/plugins/console/
!/plugins/launcher/

# Environment / secrets
.env
.env.*
!.env.example

# OS
.DS_Store
