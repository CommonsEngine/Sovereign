{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovereign.openfs.io/schemas/manifest.schema.json",
  "title": "Sovereign App Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "runtime",
    "permissions",
    "compatibility",
    "launch"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "runtime": {
      "type": "string",
      "enum": ["route-source", "iframe-local", "iframe-remote", "external"]
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "launch": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        }
      }
    },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "compatibility": {
      "type": "object",
      "required": ["minPlatformVersion"],
      "properties": {
        "minPlatformVersion": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}