{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovereign.openfs.io/schemas/manifest.schema.json",
  "title": "Sovereign App Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "runtime",
    "permissions",
    "compatibility",
    "launch"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "runtime": {
      "type": "string",
      "enum": ["internal", "vite", "iframe"]
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "launch": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["react", "html", "*"]
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9]+$"
            },
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          ]
        },
        "https": {
          "type": "boolean"
        },
        "uri": {
          "type": "string",
          "pattern": "^/"
        },
        "entrypoint": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        }
      },
      "additionalProperties": false
    },
    "extensionPoints": {
      "type": "object",
      "properties": {
        "launcher": {
          "type": "boolean"
        },
        "sidebar": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "compatibility": {
      "type": "object",
      "required": ["minPlatformVersion"],
      "properties": {
        "minPlatformVersion": { "type": "string" }
      }
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime": { "const": "internal" }
        },
        "required": ["runtime"]
      },
      "then": {
        "required": ["runtimeConfig"],
        "properties": {
          "runtimeConfig": {
            "type": "object",
            "required": ["engine"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime": { "const": "vite" }
        },
        "required": ["runtime"]
      },
      "then": {
        "required": ["runtimeConfig"],
        "properties": {
          "runtimeConfig": {
            "type": "object",
            "required": ["engine", "host", "port"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime": { "const": "iframe" },
          "runtimeConfig": {
            "type": "object",
            "required": ["entrypoint"]
          }
        },
        "required": ["runtime", "runtimeConfig"]
      },
      "then": true,
      "else": {
        "if": {
          "properties": {
            "runtime": { "const": "iframe" }
          },
          "required": ["runtime"]
        },
        "then": {
          "required": ["runtimeConfig"],
          "properties": {
            "runtimeConfig": {
              "type": "object",
              "required": ["engine", "host"]
            }
          }
        }
      }
    }
  ]
}
