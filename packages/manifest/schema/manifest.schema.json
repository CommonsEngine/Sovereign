{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sovereign.openfs.io/schemas/manifest.schema.json",
  "title": "Sovereign App Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "runtime",
    "permissions",
    "compatibility",
    "launch"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "runtime": {
      "type": "string",
      "enum": ["route-source", "iframe-local", "iframe-remote", "external"]
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "launch": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "iframeLocal": {
          "type": "object",
          "required": ["entrypoint"],
          "properties": {
            "entrypoint": {
              "type": "string",
              "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
            }
          },
          "additionalProperties": false
        },
        "iframeRemote": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": {
              "type": "string",
              "pattern": "^https://.+"
            }
          },
          "additionalProperties": false
        },
        "external": {
          "type": "object",
          "required": ["url"],
          "properties": {
            "url": {
              "type": "string",
              "pattern": "^https://.+"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "extensionPoints": {
      "type": "object",
      "properties": {
        "launcher": {
          "type": "boolean"
        },
        "sidebar": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "compatibility": {
      "type": "object",
      "required": ["minPlatformVersion"],
      "properties": {
        "minPlatformVersion": { "type": "string" }
      }
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime": { "const": "iframe-local" }
        },
        "required": ["runtime"]
      },
      "then": {
        "required": ["runtimeConfig"],
        "properties": {
          "runtimeConfig": {
            "type": "object",
            "required": ["iframeLocal"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime": { "const": "iframe-remote" }
        },
        "required": ["runtime"]
      },
      "then": {
        "required": ["runtimeConfig"],
        "properties": {
          "runtimeConfig": {
            "type": "object",
            "required": ["iframeRemote"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime": { "const": "external" }
        },
        "required": ["runtime"]
      },
      "then": {
        "required": ["runtimeConfig"],
        "properties": {
          "runtimeConfig": {
            "type": "object",
            "required": ["external"]
          }
        }
      }
    }
  ]
}
