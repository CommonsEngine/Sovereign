{
  "name": "@commonsengine/sovereign",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "platform",
    "packages/*",
    "plugins/*",
    "templates/*"
  ],
  "scripts": {
    "dev": "yarn workspace @sovereign/platform dev",
    "start": "yarn workspace @sovereign/platform start",
    "build": "yarn generate && yarn workspace @sovereign/platform build",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "typecheck": "yarn generate && yarn workspaces foreach -A run typecheck",
    "validate:manifest": "tsx tools/validate-manifest.ts",
    "generate": "tsx tools/generate-app-registry.ts"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.22.1",
    "typescript": "^5.8.3"
  }
}
